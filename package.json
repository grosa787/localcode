{
  "name": "localcode",
  "version": "0.20.0",
  "type": "module",
  "bin": {
    "localcode": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "start": "bun run src/cli.tsx",
    "build:web": "cd web-frontend && bun install && bun run build",
    "embed-web": "bun run scripts/embed-web.ts",
    "build:cli": "bun build src/cli.tsx --outdir dist --target bun --external playwright --external playwright-core --external chromium-bidi --external electron",
    "build": "bun run build:web && bun run embed-web && bun run build:cli",
    "bun": "bun run src/cli.tsx",
    "test": "bun test"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "bonjour-service": "^1.3.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "cli-highlight": "^2.1.11",
    "diff": "^7.0.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "ink": "^5.0.0",
    "pdfjs-dist": "5",
    "playwright": "^1.48.0",
    "react": "^18.3.0",
    "smol-toml": "^1.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/diff": "^5.2.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "react-devtools-core": "^7.0.1"
  }
}
